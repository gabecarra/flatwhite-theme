{
  "name": "Flatwhite",
  "type": "light",
  "$schema": "vscode://schemas/color-theme",

  "colors": {
    "editor.background":                       "#F7F3EE",
    "editor.foreground":                       "#605A52",
    "editor.lineHighlightBackground":          "#F1ECE480",
    "editor.selectionBackground":              "#DCD3C680",
    "editor.selectionHighlightBackground":     "#DCD3C640",
    "editor.wordHighlightBackground":          "#DCD3C650",
    "editor.wordHighlightStrongBackground":    "#DCD3C670",
    "editor.findMatchBackground":              "#C8BCA8",
    "editor.findMatchHighlightBackground":     "#DDD8CF80",
    "editor.hoverHighlightBackground":         "#E8E3DB",
    "editorCursor.foreground":                 "#7A4E8A",
    "editorLineNumber.foreground":             "#C8BCA8",
    "editorLineNumber.activeForeground":       "#93836C",
    "editorIndentGuide.background1":           "#E8E3DB",
    "editorIndentGuide.activeBackground1":     "#C8BCA8",
    "editorRuler.foreground":                  "#E8E3DB",
    "editorWhitespace.foreground":             "#C8BCA8",
    "editorBracketMatch.background":           "#E0D8CC",
    "editorBracketMatch.border":               "#B9A992",

    "editorBracketHighlight.foreground1":      "#C17E3A",
    "editorBracketHighlight.foreground2":      "#618A40",
    "editorBracketHighlight.foreground3":      "#2D8A78",
    "editorBracketHighlight.foreground4":      "#5070A8",
    "editorBracketHighlight.foreground5":      "#8A4E8A",
    "editorBracketHighlight.foreground6":      "#C17E3A",
    "editorBracketHighlight.unexpectedBracket.foreground": "#C05050",
    "editorError.foreground":                  "#C0392B",
    "editorWarning.foreground":                "#E67E22",
    "editorInfo.foreground":                   "#2D8A7A",
    "editorGutter.background":                 "#F7F3EE",
    "editorGutter.addedBackground":            "#7BB56B",
    "editorGutter.modifiedBackground":         "#D4A84B",
    "editorGutter.deletedBackground":          "#C0392B",
    "editorOverviewRuler.border":              "#E0D8CC",
    "editorOverviewRuler.findMatchForeground": "#C8BCA8",
    "editorOverviewRuler.selectionHighlightForeground": "#C8BCA8",

    "sideBar.background":                      "#F1ECE4",
    "sideBar.foreground":                      "#605A52",
    "sideBar.border":                          "#E0D8CC",
    "sideBarTitle.foreground":                 "#93836C",
    "sideBarSectionHeader.background":         "#EDE8E0",
    "sideBarSectionHeader.foreground":         "#93836C",
    "sideBarSectionHeader.border":             "#E0D8CC",

    "activityBar.background":                  "#EDE8E0",
    "activityBar.foreground":                  "#605A52",
    "activityBar.inactiveForeground":          "#B9A992",
    "activityBar.border":                      "#E0D8CC",
    "activityBarBadge.background":             "#7A4E8A",
    "activityBarBadge.foreground":             "#FFFFFF",

    "tab.activeBackground":                    "#F7F3EE",
    "tab.inactiveBackground":                  "#EDE8E0",
    "tab.activeForeground":                    "#605A52",
    "tab.inactiveForeground":                  "#93836C",
    "tab.border":                              "#E0D8CC",
    "tab.activeBorder":                        "#F7F3EE",
    "tab.activeBorderTop":                     "#7A4E8A",
    "editorGroupHeader.tabsBackground":        "#EDE8E0",
    "editorGroupHeader.tabsBorder":            "#E0D8CC",

    "statusBar.background":                    "#EDE8E0",
    "statusBar.foreground":                    "#605A52",
    "statusBar.border":                        "#E0D8CC",
    "statusBar.noFolderBackground":            "#EDE8E0",
    "statusBarItem.remoteBackground":          "#7A4E8A",
    "statusBarItem.remoteForeground":          "#FFFFFF",
    "statusBarItem.hoverBackground":           "#DCD3C6",

    "titleBar.activeBackground":               "#EDE8E0",
    "titleBar.activeForeground":               "#605A52",
    "titleBar.inactiveBackground":             "#F1ECE4",
    "titleBar.inactiveForeground":             "#93836C",
    "titleBar.border":                         "#E0D8CC",

    "panel.background":                        "#F1ECE4",
    "panel.border":                            "#E0D8CC",
    "panelTitle.activeForeground":             "#605A52",
    "panelTitle.inactiveForeground":           "#93836C",
    "panelTitle.activeBorder":                 "#7A4E8A",

    "input.background":                        "#F7F3EE",
    "input.foreground":                        "#605A52",
    "input.border":                            "#DCD3C6",
    "input.placeholderForeground":             "#B9A992",
    "inputOption.activeBorder":                "#7A4E8A",
    "inputOption.activeBackground":            "#EBE0EF",

    "dropdown.background":                     "#F7F3EE",
    "dropdown.foreground":                     "#605A52",
    "dropdown.border":                         "#DCD3C6",

    "button.background":                       "#7A4E8A",
    "button.foreground":                       "#FFFFFF",
    "button.hoverBackground":                  "#643E73",
    "button.secondaryBackground":              "#EDE8E0",
    "button.secondaryForeground":              "#605A52",

    "list.activeSelectionBackground":          "#DCD3C6",
    "list.activeSelectionForeground":          "#605A52",
    "list.inactiveSelectionBackground":        "#E8E3DB",
    "list.hoverBackground":                    "#E8E3DB",
    "list.focusBackground":                    "#DCD3C6",
    "list.highlightForeground":                "#7A4E8A",

    "badge.background":                        "#7A4E8A",
    "badge.foreground":                        "#FFFFFF",

    "progressBar.background":                  "#7A4E8A",

    "scrollbar.shadow":                        "#E0D8CC",
    "scrollbarSlider.background":              "#DCD3C660",
    "scrollbarSlider.hoverBackground":         "#DCD3C6A0",
    "scrollbarSlider.activeBackground":        "#C8BCA8",

    "gitDecoration.addedResourceForeground":   "#7BB56B",
    "gitDecoration.modifiedResourceForeground": "#D4A84B",
    "gitDecoration.deletedResourceForeground": "#C0392B",
    "gitDecoration.untrackedResourceForeground": "#7BB56B",
    "gitDecoration.ignoredResourceForeground": "#C8BCA8",

    "notifications.background":                "#F7F3EE",
    "notifications.foreground":                "#605A52",
    "notifications.border":                    "#E0D8CC",
    "notificationCenterHeader.background":     "#EDE8E0",

    "extensionButton.prominentBackground":     "#7A4E8A",
    "extensionButton.prominentForeground":     "#FFFFFF",
    "extensionButton.prominentHoverBackground": "#643E73",

    "peekView.border":                         "#7A4E8A",
    "peekViewEditor.background":               "#F1ECE4",
    "peekViewEditorGutter.background":         "#EDE8E0",
    "peekViewResult.background":               "#EDE8E0",
    "peekViewResult.selectionBackground":      "#DCD3C6",
    "peekViewResult.selectionForeground":      "#605A52",
    "peekViewTitle.background":                "#EDE8E0",
    "peekViewTitleLabel.foreground":           "#605A52",
    "peekViewTitleDescription.foreground":     "#93836C",

    "diffEditor.insertedTextBackground":       "#E1E9C130",
    "diffEditor.removedTextBackground":        "#F6E1C330",

    "focusBorder":                             "#7A4E8A80",
    "selection.background":                    "#7A4E8A30",

    "debugToolBar.background":                 "#EDE8E0",
    "debugToolBar.border":                     "#E0D8CC",
    "statusBar.debuggingBackground":           "#1E7A6B",
    "statusBar.debuggingForeground":           "#FFFFFF",
    "statusBar.debuggingBorder":               "#15614F",
    "editor.stackFrameHighlightBackground":    "#F6E1C350",
    "editor.focusedStackFrameHighlightBackground": "#E1E9C160"
  },

  "tokenColors": [
    {
      "name": "Base text",
      "scope": ["source", "text"],
      "settings": { "foreground": "#605A52" }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": { "foreground": "#B9A992", "fontStyle": "italic" }
    },
    {
      "name": "Punctuation and operators — secondary color",
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": { "foreground": "#93836C" }
    },

    {
      "name": "Purple — keywords (control flow, storage, declarations)",
      "scope": [
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#614C61",
        "background": "#F1DCF1"
      }
    },
    {
      "name": "Purple — HTML/XML/JSX tag names",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#614C61",
        "background": "#F1DCF1"
      }
    },
    {
      "name": "Purple-sec — tag punctuation (< > /)",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "#9C739C" }
    },
    {
      "name": "Purple-sec — keyword operators that are words",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.in",
        "keyword.operator.of",
        "keyword.operator.instanceof"
      ],
      "settings": {
        "foreground": "#614C61",
        "background": "#F1DCF1"
      }
    },

    {
      "name": "Green — strings (quoted, template, unquoted values)",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#475643",
        "background": "#E1E9C1"
      }
    },
    {
      "name": "Green-sec — string delimiters",
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": { "foreground": "#65895D" }
    },
    {
      "name": "Reset inside string interpolation",
      "scope": [
        "meta.template.expression",
        "meta.interpolation"
      ],
      "settings": {
        "foreground": "#605A52",
        "background": "#F7F3EE"
      }
    },
    {
      "name": "Green — regexp literals",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#475643",
        "background": "#E1E9C1"
      }
    },
    {
      "name": "Teal — regexp special chars",
      "scope": [
        "keyword.control.anchor.regexp",
        "keyword.operator.quantifier.regexp",
        "keyword.other.back-reference.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#465953",
        "background": "#D2EBE3"
      }
    },

    {
      "name": "Teal — language constants",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#465953",
        "background": "#D2EBE3"
      }
    },
    {
      "name": "Teal — numeric constants",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.binary",
        "constant.numeric.octal"
      ],
      "settings": {
        "foreground": "#465953",
        "background": "#D2EBE3"
      }
    },
    {
      "name": "Teal — character escapes inside strings",
      "scope": [
        "constant.character.escape",
        "constant.character"
      ],
      "settings": {
        "foreground": "#465953",
        "background": "#D2EBE3"
      }
    },

    {
      "name": "Blue — symbols, special constants, keys",
      "scope": [
        "constant.other.symbol",
        "constant.other.key",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#4C5361",
        "background": "#DDE3F1"
      }
    },
    {
      "name": "Blue-sec — symbol punctuation (colon prefix)",
      "scope": [
        "punctuation.definition.constant",
        "punctuation.definition.symbol"
      ],
      "settings": { "foreground": "#7382A0" }
    },

    {
      "name": "Orange — support functions and built-ins",
      "scope": [
        "support.function",
        "support.class",
        "support.type.builtin",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#5B5143",
        "background": "#F6E1C3"
      }
    },
    {
      "name": "Orange — language variables (this, self, super)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#5B5143",
        "background": "#F6E1C3"
      }
    },

    {
      "name": "HTML/XML — attribute names (italic secondary)",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#93836C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML/XML — attribute = sign",
      "scope": [
        "punctuation.separator.key-value.html",
        "punctuation.separator.key-value.xml"
      ],
      "settings": { "foreground": "#93836C" }
    },

    {
      "name": "CSS — property names",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "support.type.property-name.less",
        "meta.property-name"
      ],
      "settings": { "foreground": "#605A52" }
    },
    {
      "name": "CSS — property values / support constants",
      "scope": [
        "support.constant.property-value",
        "support.constant.color",
        "meta.property-value support.constant"
      ],
      "settings": {
        "foreground": "#475643",
        "background": "#E1E9C1"
      }
    },
    {
      "name": "CSS — units (px, em, rem, %…)",
      "scope": [
        "keyword.other.unit",
        "keyword.other.unit.css",
        "keyword.other.unit.scss",
        "keyword.other.unit.less"
      ],
      "settings": {
        "foreground": "#465953",
        "background": "#D2EBE3"
      }
    },
    {
      "name": "CSS — colors and hex values",
      "scope": [
        "constant.other.color",
        "constant.other.color.rgb-value",
        "constant.other.rgb-value",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#465953",
        "background": "#D2EBE3"
      }
    },
    {
      "name": "CSS — !important",
      "scope": ["keyword.other.important"],
      "settings": {
        "foreground": "#5B5143",
        "background": "#F6E1C3"
      }
    },
    {
      "name": "CSS — selectors (class, id, tag)",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": { "foreground": "#614C61" }
    },
    {
      "name": "CSS — at-rules (@media, @keyframes…)",
      "scope": [
        "keyword.control.at-rule",
        "keyword.control.at-rule.css"
      ],
      "settings": {
        "foreground": "#614C61",
        "background": "#F1DCF1"
      }
    },

    {
      "name": "JSON — keys (blue marker)",
      "scope": [
        "support.type.property-name.json",
        "string.json meta.structure.dictionary.key.json"
      ],
      "settings": {
        "foreground": "#4C5361",
        "background": "#DDE3F1"
      }
    },

    {
      "name": "YAML — keys",
      "scope": [
        "entity.name.tag.yaml",
        "string.unquoted.plain.out.yaml",
        "string.unquoted.yaml"
      ],
      "settings": {
        "foreground": "#4C5361",
        "background": "#DDE3F1"
      }
    },

    {
      "name": "Markdown — headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#614C61", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — bold",
      "scope": ["markup.bold", "punctuation.definition.bold.markdown"],
      "settings": { "foreground": "#5B5143", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — italic",
      "scope": ["markup.italic", "punctuation.definition.italic.markdown"],
      "settings": { "foreground": "#5B5143", "fontStyle": "italic" }
    },
    {
      "name": "Markdown — inline code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": {
        "foreground": "#465953",
        "background": "#D2EBE3"
      }
    },
    {
      "name": "Markdown — code blocks",
      "scope": ["markup.fenced_code", "markup.raw.block"],
      "settings": { "foreground": "#605A52" }
    },
    {
      "name": "Markdown — links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": { "foreground": "#4C6AFF" }
    },
    {
      "name": "Markdown — blockquote",
      "scope": ["markup.quote", "punctuation.definition.quote.markdown"],
      "settings": { "foreground": "#93836C", "fontStyle": "italic" }
    },
    {
      "name": "Markdown — list bullets",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#9C739C" }
    },

    {
      "name": "Function / method names — plain",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "meta.function-call.generic"
      ],
      "settings": { "foreground": "#605A52" }
    },
    {
      "name": "Class / type names — plain",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": { "foreground": "#605A52" }
    },
    {
      "name": "Type parameters / generics",
      "scope": [
        "entity.name.type.parameter",
        "storage.type.generic"
      ],
      "settings": { "foreground": "#605A52" }
    },

    {
      "name": "Invalid / deprecated",
      "scope": ["invalid"],
      "settings": { "foreground": "#C0392B" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#B9A992", "fontStyle": "strikethrough" }
    }
  ]
}
