{
  "name": "flatwhite-theme",
  "displayName": "Flatwhite Theme",
  "description": "Minimal warm light theme with marker-style syntax highlighting, ported from Atom flatwhite-syntax by Dmytro Biletskyy",
  "version": "1.2.0",
  "publisher": "gabrielCarraretto",
  "author": {
    "name": "Gabriel Carraretto",
    "email": "gabriel.carraretto@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabecarra/flatwhite-theme"
  },
  "homepage": "https://github.com/gabecarra/flatwhite-theme#readme",
  "bugs": {
    "url": "https://github.com/gabecarra/flatwhite-theme/issues"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#F7F3EE",
    "theme": "light"
  },
  "keywords": [
    "theme",
    "color-theme",
    "light",
    "flatwhite",
    "syntax",
    "warm"
  ],
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Flatwhite",
        "uiTheme": "vs",
        "path": "./themes/flatwhite-color-theme.json"
      }
    ]
  }
}
